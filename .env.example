# ─────────────────────────────────────────────────────────────
# NEXTDOT SALES ENGINE — Environment Variables
# ─────────────────────────────────────────────────────────────
# INSTRUCTIONS:
# 1. Copy this file and rename it to: .env
# 2. Fill in the two values below
# 3. NEVER commit .env to GitHub — it contains secret keys
# ─────────────────────────────────────────────────────────────

# Your Anthropic API Key
# Get it from: https://console.anthropic.com/keys
# It looks like: sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_ANTHROPIC_KEY=sk-ant-api03-YOUR_KEY_HERE

# Your Google Apps Script Web App URL
# Get it from: Google Sheet → Extensions → Apps Script → Deploy → Web App URL
# It looks like: https://script.google.com/macros/s/XXXXX/exec
REACT_APP_SHEETS_API=https://script.google.com/macros/s/AKfycbzJbniVPx5n5FMKh9v6MIIP6Lew6LmIJMDve659rLi2qvV4sfbQxi2sJBTSoOJq7FKz6Q/exec
